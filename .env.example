# Server Configuration
PORT=3000
DATABASE_URL="postgresql://username:password@localhost:5432/bbosong?schema=public"
NODE_ENV="development"

# JWT & Authentication Configuration
USER_JWT_SECRET="your-user-jwt-secret-key-change-me-in-production"
USER_JWT_EXPIRE="1h"
USER_JWT_AUDIENCE="bbosong-app"
USER_JWT_ISSUER="bbosong-server"
USER_REFRESH_TOKEN_EXPIRE="30d"
REFRESH_TOKEN_HMAC_SECRET="your-refresh-token-hmac-secret-key-change-me-in-production"

# External API Integrations (Infoteam Account & Policy)
INFOTEAM_ACCOUNT_URL="https://api.account.gistory.me/oauth"
POLICY_API_URL="https://policy.example.com/versions"
SERVICE_NAME_FOR_POLICY_VERSION="bbosong"

# Swagger UI & CORS Configuration
API_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000"
SWAGGER_USER="admin"
SWAGGER_PASSWORD="password123!"
CLIENT_ID="your-gistory-oauth-client-uuid"
SWAGGER_AUTH_URL="https://account.gistory.me/authorize"
SWAGGER_TOKEN_URL="https://api.account.gistory.me/oauth/token"

# Database Encryption Configuration
LOCAL_ENCRYPTION_KEY="your-local-32chars-encryption-key-!!!!"
LOCAL_ENCRYPTION_PEPPER="your-local-pepper-string"
